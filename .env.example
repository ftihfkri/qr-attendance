# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# Port — Railway provides this automatically; 5000 is the local default.
PORT=5000

# MySQL connection string (your koperasi DB must be reachable from Railway).
# Add ?sslaccept=strict at the end if your MySQL requires SSL.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/agm_attendance"

# Secret used to sign QR payloads.
QR_SECRET_KEY=change-me

# Password the admin types on the login page.
ADMIN_PASSWORD=change-me

# Optional: force the absolute URL embedded in QR codes (e.g. https://yourapp.up.railway.app).
# If unset, the server derives it from the incoming request, which works on Railway.
# PUBLIC_BASE_URL=https://yourapp.up.railway.app
